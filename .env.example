# Copy to .env and fill in. .env is gitignored — never commit real values.
# In production these live in AWS Secrets Manager; this file is for LOCAL dev only.

# ── Source: SQL Server on RDS ──────────────────────────────────────────────
RDS_HOST=your-db.xxxxxxxx.us-east-1.rds.amazonaws.com
RDS_PORT=1433
RDS_DB=FOOD_APP_DB
RDS_USER=admin
RDS_PASSWORD=changeme

# ── AWS ────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1

# Secrets Manager secret id the Glue job reads DB creds from at runtime.
DB_SECRET_NAME=food-app-db/rds-credentials

# ── Pipeline (medallion S3 zones + control table) ──────────────────────────
S3_BUCKET=business-insights-lake
RAW_BASE_PATH=s3://business-insights-lake/raw
PROD_BASE_PATH=s3://business-insights-lake/prod
REPORTING_BASE_PATH=s3://business-insights-lake/reporting
REJECTS_BASE_PATH=s3://business-insights-lake/rejects
WATERMARK_TABLE=watermarks
