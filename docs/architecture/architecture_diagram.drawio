        <mxCell id="fRej" value="bad rows" style="edgeStyle=orthogonalEdgeStyle;endArrow=classic;html=1;strokeColor=#C25B40;dashed=1;fontColor=#546E7A;fontSize=11;" edge="1" parent="1" source="prod" target="rejects"><mxGeometry relative="1" as="geometry"/></mxCell>

